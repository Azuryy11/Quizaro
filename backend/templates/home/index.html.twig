{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5 !important; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1 class="font-neoneon">Bienvenue sur Quizaro</h1>
    <p>L'interface utilisateur est côté frontend.</p>
    <p><a href="http://localhost:5173/">Ouvrir le frontend</a></p>
    {% if is_granted('ROLE_ADMIN') %}
        <p><a href="{{ path('admin_users_index') }}">Gérer les utilisateurs (admin)</a></p>
    {% endif %}
</div>
{% endblock %}
