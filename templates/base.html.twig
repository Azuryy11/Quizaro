<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header style="padding: 1rem; display: flex; gap: 1rem; align-items: center;">
            <a href="{{ path('app_home') }}">Accueil</a>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_users_index') }}">Admin users</a>
            {% endif %}
            <span style="margin-left: auto; color: white;">Mode API-first (UI côté frontend)</span>
        </header>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div style="margin: .5rem 1rem; color: {{ label == 'success' ? '#b6f7c1' : '#ffd1d1' }};">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </body>
</html>
